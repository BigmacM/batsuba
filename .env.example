# BUTSABA Wine & Cafe — Environment Variables
# Copy this file to .env and fill in real values before deploying.

# Google Tag Manager ID (e.g., GTM-ABC1234)
VITE_GTM_ID=GTM-XXXXXXX

# Google Analytics ID (e.g., G-ABC123DEF4)
VITE_GA_ID=G-XXXXXXXXXX

# Meta (Facebook) Pixel ID (e.g., 1234567890123456)
VITE_META_PIXEL_ID=XXXXXXXXXXXXXXXX
